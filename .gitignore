# Ambiente virtual Python
.venv/
venv/

# Cache do Python
__pycache__/
*.py[cod]
*.egg-info/

# Dados baixados (PGNs, puzzles, artigos) — mantém a pasta, ignora o conteúdo
data/raw/*
!data/raw/.gitkeep

# Datasets gerados pelo pipeline de processamento — mantém a pasta, ignora o conteúdo
data/processed/*
!data/processed/.gitkeep

# Configurações locais de IDE
.vscode/
.idea/

.omc

.claude

